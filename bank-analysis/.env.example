APP_NAME="BankAnaliz"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

LOG_CHANNEL=stack
LOG_LEVEL=debug

# MySQL için:
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=bank_analiz
DB_USERNAME=root
DB_PASSWORD=

# SQLite için (daha hızlı kurulum):
# DB_CONNECTION=sqlite
# DB_DATABASE=/absolute/path/to/database/database.sqlite

SESSION_DRIVER=database
SESSION_LIFETIME=120

# CSV yükleme için PHP limitleri
# Bunları php.ini'de de ayarlamanız gerekebilir:
# upload_max_filesize = 100M
# post_max_size = 100M
# max_execution_time = 300
# memory_limit = 512M
